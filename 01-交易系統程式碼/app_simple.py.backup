# ============================================================================
# 數據生成函數
# ============================================================================

def generate_portfolio_data(days=365):
    """生成投資組合數據"""
    np.random.seed(42)

    dates = pd.date_range(start=datetime.now() - timedelta(days=days), periods=days)

    price = 100
    prices = [price]
    returns = [0]

    for _ in range(days - 1):
        daily_return = np.random.normal(0.0008, 0.015)
        price *= (1 + daily_return)
        prices.append(price)
        returns.append(daily_return * 100)

    df = pd.DataFrame({
        'date': dates,
        'price': prices,
        'daily_return': returns,
        'cumulative_return': np.cumprod(1 + np.array(returns) / 100) * 100 - 100
    })

    return df

# 生成初始數據
df_portfolio = generate_portfolio_data()

# ============================================================================
# Google Sheets 直接連接
# ============================================================================

_sheets_cache = {}
_cache_timestamp = None

def get_sheets_data():
    """直接從 Google Sheets 讀取數據"""
    global _sheets_cache, _cache_timestamp
    from datetime import datetime as dt
    import time

    try:
        import gspread
        from google.oauth2.service_account import Credentials

        # 檢查緩存（5分鐘有效）
        current_time = time.time()
        if _cache_timestamp and (current_time - _cache_timestamp) < 300:
            if _sheets_cache.get('workbook'):
                logger.info("✅ 使用 Google Sheets 緩存連接")
                return _sheets_cache['workbook'], _sheets_cache['client']

        # 檢查必要文件
        creds_path = os.path.abspath('credentials.json')
        logger.info(f"[DEBUG] credentials.json 路徑: {creds_path}")
        logger.info(f"[DEBUG] credentials.json 存在: {os.path.exists(creds_path)}")

        if not os.path.exists(creds_path):
            logger.error("❌ 找不到 credentials.json")
            return None, None

        # 認證
        logger.info("🔐 正在認證 Google Sheets...")
        try:
            creds = Credentials.from_service_account_file(
                creds_path,
                scopes=['https://www.googleapis.com/auth/spreadsheets']
            )
            logger.info("✅ 已取得認證證書")
        except Exception as auth_err:
            logger.error(f"❌ 認證失敗: {auth_err}")
            raise

        logger.info("🔗 正在授權 gspread 客戶端...")
        client = gspread.authorize(creds)
        logger.info("✅ gspread 客戶端已授權")

        # 打開 Sheets
        sheet_id = os.getenv('GOOGLE_SHEET_KEY')
        if not sheet_id:
            logger.error("❌ 環境變數 GOOGLE_SHEET_KEY 未設置")
            return None, None

        logger.info(f"📂 正在打開 Sheet: {sheet_id[:20]}...")
        workbook = client.open_by_key(sheet_id)
        logger.info(f"✅ Google Sheets 連接成功: {workbook.title}")

        # 緩存連接
        _sheets_cache['workbook'] = workbook
        _sheets_cache['client'] = client
        _cache_timestamp = current_time

        return workbook, client

    except Exception as e:
        logger.error(f"❌ Google Sheets 連接失敗: {e}")
        import traceback
        logger.error(traceback.format_exc())
        return None, None

# ============================================================================
# 數據獲取函數
# ============================================================================

def get_holdings():
    """獲取持倉列表 - 優先從 broker_positions（同步後的實時持倉）"""
    try:
        logger.info("📊 開始讀取持倉...")
        wb, client = get_sheets_data()
        if not wb:
            logger.warning("⚠️ Google Sheets 連接失敗，無法讀取持倉")
            return []

        # 優先從 broker_positions 讀取（實時持倉 - Yuanta/IB 同步）
        logger.info("📝 正在獲取 broker_positions 工作表...")
        try:
            sheet = wb.worksheet('broker_positions')
            records = sheet.get_all_records()

            if records and len(records) > 0:
                logger.info(f"✅ 成功讀取 {len(records)} 筆持倉（來自 broker_positions）")
                return records
            else:
                logger.info("ℹ️ broker_positions 為空，嘗試 trades 表...")
        except Exception as e:
            logger.warning(f"⚠️ broker_positions 讀取失敗: {e}，嘗試 trades 表...")

        # 備用方案：從 trades 讀取當前持倉（狀態="持倉"）
        logger.info("📝 正在獲取 trades 工作表...")
        try:
            sheet = wb.worksheet('trades')
            records = sheet.get_all_records()

            if records:
                # 過濾出狀態為"持倉"的記錄
                holdings = [r for r in records if r.get('狀態', '').strip() == '持倉']
                if holdings:
                    logger.info(f"✅ 成功讀取 {len(holdings)} 筆持倉（來自 trades，狀態=持倉）")
                    return holdings
                else:
                    logger.info(f"ℹ️ trades 表有 {len(records)} 筆記錄，但無'持倉'狀態，返回全部記錄")
                    return records[:10]  # 最多返回 10 筆
        except Exception as e:
            logger.warning(f"⚠️ trades 工作表讀取失敗: {e}")

        logger.warning("⚠️ broker_positions 和 trades 工作表均無有效持倉數據")
        return []

    except Exception as e:
        logger.error(f"❌ 讀取持倉失敗: {e}")
        import traceback
        traceback.print_exc()
        return []

def get_metrics():
    """獲取儀表板指標"""
    try:
        logger.info("📈 開始讀取指標...")
        wb, client = get_sheets_data()
        if not wb:
            logger.warning("⚠️ Google Sheets 連接失敗，使用模擬數據")
            return {
                'total_value': 125345.01,
                'annual_return': 15.5,
                'sharpe_ratio': 1.2,
                'max_drawdown': -5.2,
                'daily_change': 0.5,
                'holdings': 4,
                'data_source': 'demo'
            }

        # 嘗試讀取 daily_nav
        try:
            logger.info("📝 正在獲取 daily_nav 工作表...")
            nav_sheet = wb.worksheet('daily_nav')
            nav_records = nav_sheet.get_all_records()

            if nav_records:
                latest = nav_records[-1]
                logger.info(f"✅ 成功讀取 daily_nav，共 {len(nav_records)} 筆記錄")
                return {
                    'total_value': float(latest.get('nav_usd', 0)),
                    'annual_return': float(latest.get('cumulative_return_pct', 0)),
                    'sharpe_ratio': float(latest.get('sharpe_ratio', 0)),
                    'max_drawdown': float(latest.get('mdd_pct', 0)),
                    'daily_change': float(latest.get('daily_return_pct', 0)),
                    'holdings': 0,
                    'data_source': 'sheets'
                }

            logger.warning("⚠️ daily_nav 工作表為空")
        except Exception as e:
            logger.warning(f"⚠️ 讀取 daily_nav 失敗: {e}")

        # 返回空指標
        logger.info("ℹ️ 返回空指標對象")
        return {
            'total_value': 0,
            'annual_return': 0,
            'sharpe_ratio': 0,
            'max_drawdown': 0,
            'daily_change': 0,
            'holdings': 0,
            'data_source': 'none'
        }

    except Exception as e:
        logger.error(f"❌ 獲取指標失敗: {e}")
        import traceback
        traceback.print_exc()
        return None

