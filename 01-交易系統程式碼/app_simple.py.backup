@strategy_bp.route('/api/intel/usgs', methods=['GET'])
def api_intel_usgs():
    """API：調用 USGS Earthquake API 並返回今日地震"""
    try:
        import requests
        from datetime import datetime, timedelta

        # 調用 USGS 公開 API（免費）
        url = "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/4.5_day.geojson"
        response = requests.get(url, timeout=10)

        if response.status_code != 200:
            return jsonify({'status': 'error', 'message': 'USGS API 連接失敗'}), 503

        data = response.json()
        earthquakes = []

        for feature in data.get('features', []):
            props = feature.get('properties', {})
            geom = feature.get('geometry', {})
            coords = geom.get('coordinates', [0, 0])

            earthquakes.append({
                'time': datetime.fromtimestamp(props.get('time', 0) / 1000).isoformat(),
                'magnitude': props.get('mag', 0),
                'location': props.get('place', ''),
                'latitude': coords[1],
                'longitude': coords[0],
                'depth_km': coords[2] if len(coords) > 2 else 0,
                'url': props.get('url', '')
            })

        # 可選：寫入 intel_events 表
        # from sheets_utils import write_intel_event
        # for eq in earthquakes:
        #     write_intel_event({
        #         'date': eq['time'],
        #         'event_type': 'earthquake',
        #         'location': eq['location'],
        #         'severity': 'HIGH' if eq['magnitude'] > 6 else 'MEDIUM',
        #         'llm_risk_score': eq['magnitude'],
        #         'summary': f"Magnitude {eq['magnitude']} earthquake at {eq['location']}",
        #         'impact_assets': 'Energy, Commodities'
        #     })

        return jsonify({'status': 'success', 'earthquakes': earthquakes, 'count': len(earthquakes)}), 200

    except requests.exceptions.Timeout:
        logger.error("USGS API 連接超時")
        return jsonify({'status': 'error', 'message': '地震數據加載超時'}), 504
    except Exception as e:
        logger.error(f"USGS API 調用失敗: {e}")
        return jsonify({'status': 'error', 'message': str(e)}), 500


