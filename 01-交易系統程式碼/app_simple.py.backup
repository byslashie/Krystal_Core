# ============================================================================
# 策略管理 API 路由 - 使用 Blueprint 避免 Flask routing bug
# ============================================================================

# 创建蓝图来避免 Flask 3.1.3 的 routing bug
strategy_bp = Blueprint('strategy_api', __name__)

@strategy_bp.route('/api/strategies', methods=['GET'])
def api_strategies():
    """API：獲取所有策略列表 + 績效匯總"""
    try:
        from sheets_utils import read_strategies, read_daily_nav, read_trades

        strategies_df = read_strategies()
        daily_nav_df = read_daily_nav()
        trades_df = read_trades()

        if strategies_df.empty:
            return jsonify({'status': 'success', 'strategies': []}), 200

        result = []
        for _, row in strategies_df.iterrows():
            strategy_name = row.get('策略名稱', '')

            # 計算最新 NAV 和累積報酬
            nav = None
            cumret = None
            if not daily_nav_df.empty:
                strat_nav = daily_nav_df[daily_nav_df['策略'] == strategy_name]
                if not strat_nav.empty:
                    latest = strat_nav.iloc[-1]
                    nav = float(latest.get('NAV', 1)) if latest.get('NAV') else None
                    cumret = latest.get('累積報酬', '0%')

            # 統計交易
            trades_count = 0
            holding_count = 0
            if not trades_df.empty:
                strat_trades = trades_df[trades_df['策略'] == strategy_name]
                trades_count = len(strat_trades)
                holding_count = len(strat_trades[strat_trades['狀態'] == '持倉'])

            result.append({
                '策略名稱': strategy_name,
                '狀態': row.get('狀態', ''),
                '策略類型': row.get('策略類型', ''),
                '風險等級': row.get('風險等級', ''),
                '起始資金': str(row.get('起始資金', '')),
                '幣別': row.get('幣別', ''),
                'nav': nav,
                'cumret': cumret,
                'trades_count': trades_count,
                'holding_count': holding_count
            })

        return jsonify({'status': 'success', 'strategies': result}), 200

    except Exception as e:
        logger.error(f"獲取策略列表失敗: {e}")
        return jsonify({'status': 'error', 'message': str(e)}), 500


@strategy_bp.route('/api/strategies/performance', methods=['GET'])
def api_strategies_performance():
    """API：獲取所有策略的 NAV 時間序列"""
    try:
        from sheets_utils import read_daily_nav

        daily_nav_df = read_daily_nav()

        if daily_nav_df.empty:
            return jsonify({'status': 'success', 'data': {}}), 200

        # 按策略分組
        result = {}
        for strategy in daily_nav_df['策略'].unique():
            strat_data = daily_nav_df[daily_nav_df['策略'] == strategy]
            result[strategy] = [
                {'date': str(row.get('日期', '')), 'nav': float(row.get('NAV', 1))}
                for _, row in strat_data.iterrows()
            ]

        return jsonify({'status': 'success', 'data': result}), 200

    except Exception as e:
        logger.error(f"獲取策略績效失敗: {e}")
        return jsonify({'status': 'error', 'message': str(e)}), 500


@strategy_bp.route('/api/upload-csv', methods=['POST'])
def api_upload_csv():
    """API：上傳 CSV 並計算績效指標"""
    try:
        # 檢查檔案
        if 'csv_file' not in request.files:
            return jsonify({'status': 'error', 'message': '未上傳檔案'}), 400

        file = request.files['csv_file']
        strategy_name = request.form.get('strategy_name', 'Uploaded Strategy')
        initial_capital = float(request.form.get('initial_capital', 100000))

        if file.filename == '':
            return jsonify({'status': 'error', 'message': '檔案名稱為空'}), 400

        # 讀取 CSV
        import io
        try:
            content = file.read().decode('cp950')
        except:
            content = file.read().decode('utf-8')

        csv_df = pd.read_csv(io.StringIO(content))

        # 簡單的績效計算
        if csv_df.empty:
            return jsonify({'status': 'error', 'message': 'CSV 為空'}), 400

        # 嘗試找出報酬率欄位
        pnl_cols = [c for c in csv_df.columns if '獲利' in c or 'pnl' in c.lower() or '報酬' in c]

        metrics = {
            'strategy_name': strategy_name,
            'initial_capital': initial_capital,
            'rows': len(csv_df),
            'status': 'analyzed'
        }

        # 如果有報酬欄位，計算指標
        if pnl_cols:
            pnl_col = pnl_cols[0]
            pnl_series = pd.to_numeric(csv_df[pnl_col], errors='coerce').dropna()

            if len(pnl_series) > 0:
                total_pnl = pnl_series.sum()
                win_count = (pnl_series > 0).sum()
                win_rate = win_count / len(pnl_series) if len(pnl_series) > 0 else 0

                metrics.update({
                    'total_pnl': float(total_pnl),
                    'trades': len(pnl_series),
                    'win_rate': f'{win_rate*100:.2f}%',
                    'avg_win': float(pnl_series[pnl_series > 0].mean()) if (pnl_series > 0).any() else 0
                })

        return jsonify({'status': 'success', 'metrics': metrics}), 200

    except Exception as e:
        logger.error(f"CSV 上傳失敗: {e}")
        return jsonify({'status': 'error', 'message': str(e)}), 500


@strategy_bp.route('/api/trades/update', methods=['POST'])
def api_trades_update():
    """API：更新交易記錄"""
    try:
        from sheets_utils import update_trade_by_id

        data = request.get_json()
        trade_id = data.get('id')

        if not trade_id:
            return jsonify({'status': 'error', 'message': '缺少交易 ID'}), 400

        # 準備更新資料
        update_dict = {}
        if '進場原因' in data:
            update_dict['進場原因'] = data['進場原因']
        if '出場原因' in data:
            update_dict['出場原因'] = data['出場原因']
        if '備註' in data:
            update_dict['備註'] = data['備註']
        if '策略' in data:
            update_dict['策略'] = data['策略']

        success = update_trade_by_id(trade_id, update_dict)

        if success:
            return jsonify({'status': 'success', 'message': '交易已更新'}), 200
        else:
            return jsonify({'status': 'error', 'message': '更新失敗'}), 500

    except Exception as e:
        logger.error(f"更新交易失敗: {e}")
        return jsonify({'status': 'error', 'message': str(e)}), 500


@strategy_bp.route('/api/risk-metrics', methods=['GET'])
def api_risk_metrics():
    """API：獲取整體投資組合風控指標"""
    try:
        from sheets_utils import read_daily_nav
        import numpy as np

        daily_nav_df = read_daily_nav()

        if daily_nav_df.empty:
            return jsonify({'status': 'success', 'metrics': {}}), 200

        # 計算投資組合總體指標
        # 假設每行是一個日期的快照，計算回報率
        nav_values = pd.to_numeric(daily_nav_df['NAV'], errors='coerce').dropna().values

        metrics = {}

        if len(nav_values) > 1:
            returns = np.diff(nav_values) / nav_values[:-1]

            # Sharpe Ratio
            mean_ret = returns.mean()
            std_ret = returns.std()
            sharpe = (mean_ret / std_ret * np.sqrt(252)) if std_ret > 0 else 0

            # MDD
            cumsum_nav = pd.Series(np.cumprod(1 + returns))
            rolling_max = cumsum_nav.cummax()
            mdd = ((cumsum_nav / rolling_max - 1).min())

            # VaR 95%
            var_95 = np.percentile(returns, 5)

            metrics = {
                'sharpe_ratio': round(sharpe, 4),
                'max_drawdown': f'{mdd*100:.2f}%',
                'var_95': f'{var_95*100:.2f}%',
                'total_days': len(nav_values),
                'status': 'calculated'
            }

        return jsonify({'status': 'success', 'metrics': metrics}), 200

    except Exception as e:
        logger.error(f"計算風控指標失敗: {e}")
        return jsonify({'status': 'error', 'message': str(e)}), 500


