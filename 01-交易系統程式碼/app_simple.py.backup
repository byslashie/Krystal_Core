@app.route('/')
def index():
    """主頁 - 打開時自動同步 broker_positions"""
    import threading
    from datetime import datetime, timedelta

    # 檢查是否需要同步（一天最多同步一次）
    last_sync_file = 'last_sync_timestamp.txt'
    should_sync = True

    try:
        with open(last_sync_file, 'r') as f:
            last_sync = datetime.fromisoformat(f.read().strip())
            if datetime.now() - last_sync < timedelta(hours=24):
                should_sync = False
                logger.info(f"⏭️ 跳過同步（距上次同步不足 24 小時）")
    except:
        pass

    # 後台執行同步（不阻塞主線程）
    if should_sync:
        def sync_in_background():
            try:
                logger.info("🔄 背景同步 broker_positions...")
                # 調用同步邏輯
                positions_data = []

                # 從各個 Broker 獲取數據
                try:
                    from brokers.ib_api import get_open_positions as ib_get_open_positions
                    ib_positions = ib_get_open_positions()
                    if ib_positions:
                        positions_data.extend(ib_positions)
                        logger.info(f"✅ IB: 獲取 {len(ib_positions)} 筆持倉")
                except Exception as e:
                    logger.warning(f"⚠️ IB 同步失敗: {e}")

                try:
                    import time
                    from brokers.yuanta_api import yuanta_login, fetch_positions, register_events, query_stock_positions
                    logger.info("⏳ Yuanta 同步開始...")
                    api = yuanta_login()
                    register_events(api)
                    # 等待登入生效
                    logger.info("⏳ 等待 API 初始化 (10s)...")
                    time.sleep(10)
                    # 發送庫存查詢（帶重試機制）
                    ok = False
                    for attempt in range(1, 3):
                        logger.info(f"⏳ Yuanta 查詢嘗試 {attempt}/2...")
                        ok = query_stock_positions(api)
                        if ok:
                            logger.info("✅ Yuanta 查詢成功")
                            break
                        time.sleep(3)
                    if not ok:
                        logger.warning("⚠️ Yuanta 查詢發送失敗，但繼續等待回應...")
                    # 等待非同步回應
                    logger.info("⏳ 等待 Yuanta 回應 (12s)...")
                    time.sleep(12)
                    yuanta_positions = fetch_positions(api)
                    logger.info(f"✅ Yuanta 回應完成：{len(yuanta_positions)} 筆持倉")
                    if yuanta_positions:
                        # Yuanta 返回 CSV 格式字符串，需要解析
                        parsed_positions = []
                        for pos in yuanta_positions:
                            if isinstance(pos, str) and ',' in pos:
                                parts = pos.split(',')
                                if len(parts) >= 8:
                                    try:
                                        parsed_positions.append({
                                            'broker': 'Yuanta',
                                            'symbol': parts[4],
                                            'quantity': float(parts[6]),
                                            'avg_price': float(parts[7]),
                                            'cost_raw': float(parts[8]) if len(parts) > 8 else 0
                                        })
                                    except (ValueError, IndexError):
                                        pass
                        if parsed_positions:
                            positions_data.extend(parsed_positions)
                            logger.info(f"✅ Yuanta: 獲取 {len(parsed_positions)} 筆持倉")
                except Exception as e:
                    logger.warning(f"⚠️ Yuanta 同步失敗: {e}")

                if positions_data:
                    # 寫入 Google Sheets
                    wb, client = get_sheets_data()
                    if wb:
                        sheet = wb.worksheet('broker_positions')
                        sheet.clear()

                        headers = list(positions_data[0].keys()) if positions_data else []
                        if headers:
                            sheet.append_row(headers)
                            for pos in positions_data:
                                sheet.append_row([pos.get(h, '') for h in headers])

                        logger.info(f"✅ 成功同步 {len(positions_data)} 筆 broker_positions")

                        # 記錄同步時間
                        with open(last_sync_file, 'w') as f:
                            f.write(datetime.now().isoformat())
            except Exception as e:
                logger.error(f"❌ 背景同步失敗: {e}")

        # 在後台線程執行（不阻塞頁面加載）
        thread = threading.Thread(target=sync_in_background, daemon=True)
        thread.start()

    metrics = get_metrics() or {}
    return render_template('dashboard.html', metrics=metrics)

@app.route('/api/metrics')
def api_metrics():
    """API：獲取指標"""
    metrics = get_metrics()
    if metrics:
        return jsonify({
            'status': 'success',
            'data': metrics
        })
    return jsonify({'status': 'error', 'message': '無法獲取指標'}), 500

@app.route('/api/sync-broker-positions', methods=['POST'])
def sync_broker_positions():
    """同步 broker_positions 數據到 Google Sheets"""
    try:
        logger.info("🔄 開始同步 broker_positions...")

        # 嘗試從各個 Broker 獲取數據
        positions_data = []

        # 從 Interactive Brokers
        try:
            from brokers.ib_api import get_open_positions as ib_get_open_positions
            ib_positions = ib_get_open_positions()
            if ib_positions:
                logger.info(f"📥 IB: 獲取 {len(ib_positions)} 筆持倉")
                positions_data.extend(ib_positions)
        except Exception as e:
            logger.warning(f"⚠️ IB 同步失敗: {e}")

        # 從 Yuanta（元大）
        try:
            import time
            from brokers.yuanta_api import yuanta_login, fetch_positions, register_events, query_stock_positions
            logger.info("⏳ [POST] Yuanta 同步開始...")
            api = yuanta_login()
            logger.info("[OK] Yuanta 登入成功")
            register_events(api)
            logger.info("[OK] 事件已註冊")
            # 等待登入生效
            logger.info("⏳ 等待 API 初始化 (10s)...")
            time.sleep(10)
            # 發送庫存查詢
            ok = False
            for attempt in range(1, 3):
                logger.info(f"⏳ Yuanta 查詢嘗試 {attempt}/2...")
                ok = query_stock_positions(api)
                if ok:
                    logger.info("✅ Yuanta 查詢成功")
                    break
                time.sleep(3)
            # 等待非同步回應
            logger.info("⏳ 等待 Yuanta 回應 (12s)...")
            time.sleep(12)
            yuanta_positions = fetch_positions(api)
            logger.info(f"✅ Yuanta 回應：{len(yuanta_positions)} 筆持倉")
            if yuanta_positions:
                # Yuanta 返回 CSV 格式字符串，需要解析
                parsed_positions = []
                for pos in yuanta_positions:
                    if isinstance(pos, str) and ',' in pos:
                        parts = pos.split(',')
                        if len(parts) >= 8:
                            try:
                                parsed_positions.append({
                                    'broker': 'Yuanta',
                                    'symbol': parts[4],
                                    'quantity': float(parts[6]),
                                    'avg_price': float(parts[7]),
                                    'cost_raw': float(parts[8]) if len(parts) > 8 else 0
                                })
                            except (ValueError, IndexError):
                                pass
                if parsed_positions:
                    logger.info(f"📥 Yuanta: 獲取 {len(parsed_positions)} 筆持倉")
                    positions_data.extend(parsed_positions)
                else:
                    logger.warning("[WARN] Yuanta 解析失敗 - 無有效持倉")
            else:
                logger.warning("[WARN] Yuanta fetch_positions 返回空")
        except Exception as e:
            logger.error(f"❌ Yuanta 同步失敗: {e}")
            import traceback
            logger.error(traceback.format_exc())

        logger.info(f"=" * 60)
        logger.info(f"📊 同步結果: {len(positions_data)} 筆持倉")
        logger.info(f"=" * 60)

        if positions_data:
            # 嘗試寫入 Google Sheets
            try:
                logger.info("[Google Sheets] 嘗試連接...")
                wb, client = get_sheets_data()
                if wb:
                    logger.info("[Google Sheets] 連接成功，寫入數據...")
                    sheet = wb.worksheet('broker_positions')
                    sheet.clear()
                    logger.info("[Google Sheets] 已清空表")

                    headers = list(positions_data[0].keys())
                    sheet.append_row(headers)
                    logger.info(f"[Google Sheets] 已寫入表頭: {headers}")

                    for pos in positions_data:
                        sheet.append_row([pos.get(h, '') for h in headers])

                    logger.info(f"✅ 成功寫入 {len(positions_data)} 筆到 Google Sheets")
                else:
                    logger.warning("[Google Sheets] 連接失敗，但持倉數據已取得")
            except Exception as gs_error:
                logger.warning(f"[Google Sheets] 寫入失敗: {gs_error}，但持倉數據已取得")

            # 無論 Google Sheets 是否成功，只要有數據就返回成功
            return jsonify({
                'status': 'success',
                'message': f'成功同步 {len(positions_data)} 筆持倉',
                'count': len(positions_data)
            })
        else:
            logger.error("❌ 無法從任何 Broker 獲取持倉數據")
            return jsonify({'status': 'warning', 'message': '未能從任何 Broker 獲取持倉數據'}), 400

    except Exception as e:
        logger.error(f"❌ 同步失敗: {e}")
        import traceback
        logger.error(traceback.format_exc())
        return jsonify({'status': 'error', 'message': str(e)}), 500

@app.route('/api/holdings')
def api_holdings():
    """API：獲取持倉 - 轉換為前端期望格式"""
    try:
        print("[ROUTE] GET /api/holdings", flush=True)
        logger.info("🔗 API: 獲取持倉請求")
        holdings = get_holdings()
        logger.info(f"📦 持倉數量: {len(holdings)} 筆")

        # 轉換數據格式（trades 表 → 前端期望格式）
        import json
        converted_holdings = []

        for item in holdings:
            try:
                # 从 trades 表或 broker_positions 转换
                # trades 表字段：標的、進場價、數量、策略等
                # broker_positions 字段：symbol、position、avgCost 等

                converted = {
                    'symbol': str(item.get('標的') or item.get('symbol') or '-'),
                    'price': float(item.get('進場價') or item.get('avgCost') or 0),
                    'quantity': int(item.get('數量') or item.get('position') or 0),
                    'value': float(item.get('市值') or 0),
                    'change': item.get('漲跌', '0%')
                }

                # 計算市值（如果沒有）
                if converted['value'] == 0 and converted['price'] > 0 and converted['quantity'] > 0:
                    converted['value'] = converted['price'] * converted['quantity']

                converted_holdings.append(converted)
            except Exception as e:
                logger.warning(f"⚠️ 轉換持倉失敗: {e}")
                continue

        # 確保所有數據都可序列化
        safe_holdings = json.loads(json.dumps(converted_holdings, default=str))

        return jsonify({
            'status': 'success',
            'data': safe_holdings,
            'count': len(converted_holdings),
            'source': 'sheets' if holdings else 'empty',
            'timestamp': datetime.now().isoformat()
        })
    except Exception as e:
        logger.error(f"❌ /api/holdings 錯誤: {e}")
        import traceback
        logger.error(traceback.format_exc())
        return jsonify({'status': 'error', 'message': str(e)}), 500

@app.route('/api/status')
def api_status():
    """API：系統狀態"""
    wb, _ = get_sheets_data()
    return jsonify({
        'app': 'running',
        'sheets': wb is not None,
        'timestamp': datetime.now().isoformat()
    })

@app.route('/api/routes')
def api_routes():
    """List all registered routes"""
    routes = []
    for rule in app.url_map.iter_rules():
        if '/api/' in str(rule):
            methods = ','.join(rule.methods - {'HEAD', 'OPTIONS'})
            routes.append(f"{methods:8} {rule.rule}")
    return jsonify({
        'status': 'success',
        'total': len(routes),
        'routes': sorted(routes)
    }), 200

@app.route('/api/debug')
def api_debug():
    """API：調試信息"""
    wb, _ = get_sheets_data()

    debug_info = {
        'sheets_connected': wb is not None,
        'metrics': get_metrics(),
        'holdings_count': len(get_holdings()),
        'timestamp': datetime.now().isoformat()
    }

    return jsonify(debug_info)

@app.route('/api/chart-data')
